      document.querySelectorAll('#tkFasilitasGrid .fasil-chip').forEach(chip => {
        chip.classList.toggle('active', kosFasilitas.includes(chip.textContent.trim()));
      });
    } else {
      // MODE TAMBAH BARU — kosongkan form
      titleEl.textContent = '➕ Tambah Kos Baru';
      btnEl.textContent = '💾 Simpan & Publikasikan';
      jumlahKamarGroup.style.display = 'block';

      document.getElementById('tkNamaKos').value = '';
      document.getElementById('tkAlamat').value = '';
      document.getElementById('tkDeskripsi').value = '';
      document.getElementById('tkHarga').value = '';
      document.getElementById('tkJumlahKamar').value = '';
      document.getElementById('tkKoordinat').value = '';
      document.querySelectorAll('#tkJenisGrid .jenis-btn').forEach((btn, i) => btn.classList.toggle('active', i === 0));
      document.querySelectorAll('#tkFasilitasGrid .fasil-chip').forEach(chip => chip.classList.remove('active'));
