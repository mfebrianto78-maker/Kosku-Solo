  let editingKosId = null; // null = mode tambah baru, ada isi = mode edit

  function showKelolaKos() {
    show('kelola-kos', 'owner');
    renderKelolaKosList();
  }

  function renderKelolaKosList() {
    const container = document.getElementById('kelolaKosList');
    if (!myKosData.length) {
      container.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text-3);font-size:13px">Belum ada kos. Tambahkan kos pertama Anda!</div>';
      return;
    }
    container.innerHTML = myKosData.map(kos => {
      const emoji = kos.jenis_kos === 'Putra' ? '🪑' : kos.jenis_kos === 'Eksklusif' ? '🏠' : '🛏️';
      const jumlahKamar = (kos.kamar || []).length;
      const statusClass = kos.status === 'aktif' ? 'kk-status-aktif' : 'kk-status-nonaktif';
      const statusLabel = kos.status === 'aktif' ? '✓ Aktif' : '○ Nonaktif';
      return `
        <div class="kk-card">
          <div class="kk-card-top">
            <div class="kk-img">${emoji}</div>
            <div style="flex:1">
              <div class="kk-name">${kos.nama_kos}</div>
              <div class="kk-addr">📍 ${kos.alamat}</div>
              <div class="kk-meta">${formatRupiah(kos.harga_per_bulan)}/bln • ${jumlahKamar} kamar</div>
            </div>
            <div class="kk-status-toggle ${statusClass}" onclick="toggleStatusKos('${kos.id}', '${kos.status}')">${statusLabel}</div>
          </div>
          <div class="kk-actions">
            <button class="kk-btn kk-btn-edit" onclick="showTambahKos('${kos.id}')">✏️ Edit</button>
            <button class="kk-btn kk-btn-delete" onclick="confirmDeleteKos('${kos.id}', '${kos.nama_kos.replace(/'/g, "\\'")}')">🗑️ Hapus</button>
          </div>
        </div>`;
    }).join('');
  }

  // Aktifkan / nonaktifkan kos (toggle status)
  async function toggleStatusKos(kosId, currentStatus) {
    const newStatus = currentStatus === 'aktif' ? 'nonaktif' : 'aktif';
    try {
      const { error } = await sbClient.from('kos').update({ status: newStatus }).eq('id', kosId);
      if (error) throw error;
      await loadMyKos();
      await loadKosData();
      renderKelolaKosList();
    } catch (err) {
      console.error(err);
      alert('Gagal mengubah status kos.');
