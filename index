<script>
  // ============================================
  // SUPABASE SETUP
  // ============================================
  const SUPABASE_URL = 'https://kyytbtkeivjzfzxgzzdm.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_czOkAsxCHGfXYgabjRPoPA_zNkv3OrH';
  // Note: variable renamed to sbClient to avoid conflict with the supabase-js CDN global namespace
  const sbClient = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  let currentUser = null; // logged in user session
  let currentUserProfile = null; // row from profiles table

  let allKosData = []; // cache data kos dari Supabase
  let selectedKos = null; // kos yang sedang dilihat di Detail

  // Format angka ke Rupiah
  function formatRupiah(num) {
    return 'Rp ' + Number(num).toLocaleString('id-ID');
  }

  // Render satu kos-card (untuk Dashboard)
  function renderKosCard(kos) {
    const emoji = kos.jenis_kos === 'Putra' ? '🪑' : kos.jenis_kos === 'Eksklusif' ? '🏠' : '🛏️';
    const badgeColor = kos.jenis_kos === 'Putra' ? '#3B82F6' : kos.jenis_kos === 'Campur' ? '#8B5CF6' : 'var(--orange)';
    return `
      <div class="kos-card" onclick="openDetail('${kos.id}')">
        <div class="kos-card-img">
          ${emoji}
          <div class="kos-badge" style="background:${badgeColor}">${kos.jenis_kos}</div>
          <div class="fav-btn" onclick="event.stopPropagation()">🤍</div>
        </div>
        <div class="kos-card-body">
          <div class="kos-name">${kos.nama_kos}</div>
          <div class="kos-addr">📍 ${kos.alamat}</div>
          <div class="kos-footer">
            <div class="kos-price">${formatRupiah(kos.harga_per_bulan)}<span>/bln</span></div>
            <div class="kos-rating">⭐ ${kos.rating} <span style="color:var(--text-3);font-weight:400">(${kos.jumlah_review})</span></div>
          </div>
        </div>
      </div>`;
  }

  // Render satu kos-list-card (untuk halaman Search)
  function renderKosListCard(kos) {
    const emoji = kos.jenis_kos === 'Putra' ? '🪑' : kos.jenis_kos === 'Eksklusif' ? '🏠' : '🛏️';
    return `
      <div class="kos-list-card" onclick="openDetail('${kos.id}')">
        <div class="kos-list-img">${emoji}</div>
        <div class="kos-list-info">
          <div class="kos-list-name">${kos.nama_kos}</div>
          <div class="kos-list-addr">📍 ${kos.alamat}</div>
          <div class="kos-list-price">${formatRupiah(kos.harga_per_bulan)}<span style="font-size:11px;color:var(--text-3);font-weight:400">/bln</span></div>
          <div class="kos-list-footer">
            <span style="font-size:12px;color:var(--text-3)">⭐ ${kos.rating} (${kos.jumlah_review}) • ${kos.jenis_kos}</span>
            <div class="fav-btn" style="position:static;box-shadow:none;font-size:14px" onclick="event.stopPropagation()">🤍</div>
          </div>
        </div>
      </div>`;
  }

  // Ambil data kos dari Supabase
  async function loadKosData() {
    try {
      const { data, error } = await sbClient
        .from('kos')
        .select('*')
        .eq('status', 'aktif')
        .order('created_at', { ascending: false });

      if (error) throw error;
      allKosData = data || [];

      // Ambil nama-nama pemilik secara terpisah (aman, tidak mengganggu data kos utama jika gagal)
      try {
        const ownerIds = [...new Set(allKosData.map(k => k.owner_id).filter(Boolean))];
        if (ownerIds.length) {
          const { data: owners } = await sbClient.from('profiles').select('id, nama_lengkap').in('id', ownerIds);
          const ownerMap = {};
          (owners || []).forEach(o => { ownerMap[o.id] = o.nama_lengkap; });
          allKosData.forEach(k => { k.owner_nama = ownerMap[k.owner_id] || 'Pemilik Kos'; });
        }
      } catch (ownerErr) {
        console.error('Gagal memuat nama pemilik:', ownerErr);
      }

      // Render ke Dashboard (ambil 4 teratas sebagai rekomendasi)
      const dashGrid = document.getElementById('dashboardKosGrid');
      if (dashGrid) {
        dashGrid.innerHTML = allKosData.length
          ? allKosData.slice(0, 4).map(renderKosCard).join('')
          : '<div style="text-align:center;padding:40px 0;color:var(--text-3);font-size:13px">Belum ada data kos.</div>';
      }

      // Render ke halaman Search
      const searchList = document.getElementById('searchResultsList');
      if (searchList) {
        searchList.innerHTML = allKosData.length
          ? allKosData.map(renderKosListCard).join('')
          : '<div style="text-align:center;padding:40px 0;color:var(--text-3);font-size:13px">Belum ada data kos.</div>';
      }
      const resultsCount = document.getElementById('resultsCount');
      if (resultsCount) {
        resultsCount.innerHTML = `Ditemukan <strong>${allKosData.length} kos</strong> di Solo`;
      }
    } catch (err) {
      console.error('Gagal memuat data kos:', err);
      const dashGrid = document.getElementById('dashboardKosGrid');
      if (dashGrid) {
        dashGrid.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--red);font-size:13px">Gagal memuat data. Cek koneksi Supabase.</div>';
      }
    }
  }

  // Buka detail kos berdasarkan ID, simpan ke selectedKos, lalu render halaman detail
  function openDetail(kosId) {
    const kos = allKosData.find(k => k.id === kosId);
    if (!kos) return;
    selectedKos = kos;
    renderDetailScreen(kos);
    showDetail();
  }

  // Render halaman Detail Kos berdasarkan data dari Supabase
  function renderDetailScreen(kos) {
    const emoji = kos.jenis_kos === 'Putra' ? '🪑' : kos.jenis_kos === 'Eksklusif' ? '🏠' : '🛏️';
    document.querySelector('#screen-detail .detail-name').textContent = kos.nama_kos;
    document.querySelector('#screen-detail .detail-addr').textContent = '📍 ' + kos.alamat;
    document.querySelector('#screen-detail .detail-price').innerHTML = formatRupiah(kos.harga_per_bulan) + '<span>/bulan</span>';
    document.querySelector('#screen-detail .rating-val').textContent = kos.rating;
    document.querySelector('#screen-detail .rating-count').textContent = `(${kos.jumlah_review} ulasan)`;
    document.querySelector('#screen-detail .detail-photos').innerHTML =
      emoji + `<div class="detail-back" onclick="showSearch()">←</div><div class="photo-count">📷 ${(kos.foto_urls||[]).length || 0} Foto</div>`;

    const descEl = document.querySelector('#screen-detail .detail-body div[style*="line-height:1.8"]');
    if (descEl) descEl.innerHTML = (kos.deskripsi || 'Belum ada deskripsi.') + ' <span style="color:var(--orange);font-weight:600;cursor:pointer">Selengkapnya...</span>';

    // Render fasilitas
    const fasilGrid = document.querySelectorAll('#screen-detail .fasil-grid')[0];
    if (fasilGrid && kos.fasilitas) {
      fasilGrid.innerHTML = kos.fasilitas.map(f => `<div class="fasil-tag">✨ ${f}</div>`).join('');
    }

    // Nama pemilik kos (dari join profiles), dipakai juga di halaman Chat
    const ownerName = kos.owner_nama || 'Pemilik Kos';
    const ownerNameEl = document.getElementById('detailOwnerName');
    if (ownerNameEl) ownerNameEl.textContent = ownerName;
    const chatNameEl = document.querySelector('#screen-chat .chat-name');
    if (chatNameEl) chatNameEl.textContent = ownerName;
  }

  // ============================================
  // BOOKING
  // ============================================
  let bookingKamarList = []; // daftar kamar kosong untuk kos yang dipilih
  let pendingBookingId = null; // booking yang baru dibuat, dipakai di halaman payment

  // Buka halaman booking untuk kos yang sedang dilihat di Detail
  async function openBookingScreen() {
    if (!currentUser) {
      alert('Silakan login dahulu untuk melakukan booking.');
      showLogin();
      return;
    }
    if (!selectedKos) return;

    hideAuthError('bkError');
    document.getElementById('bkKosName').textContent = selectedKos.nama_kos;
    document.getElementById('bkKosAddr').textContent = '📍 ' + selectedKos.alamat;
    document.getElementById('bkKosHarga').textContent = formatRupiah(selectedKos.harga_per_bulan) + '/bln';
    const emoji = selectedKos.jenis_kos === 'Putra' ? '🪑' : selectedKos.jenis_kos === 'Eksklusif' ? '🏠' : '🛏️';
    document.getElementById('bkKosImg').textContent = emoji;

    // Prefill nama & HP dari profil jika ada
    document.getElementById('bkNama').value = currentUserProfile ? (currentUserProfile.nama_lengkap || '') : '';
    document.getElementById('bkHp').value = currentUserProfile ? (currentUserProfile.no_hp || '') : '';

    // Set tanggal minimum = hari ini
    const todayStr = new Date().toISOString().split('T')[0];
    document.getElementById('bkTanggalMasuk').min = todayStr;
    document.getElementById('bkTanggalMasuk').value = todayStr;

    // Ambil daftar kamar kosong untuk kos ini
    const selectEl = document.getElementById('bkKamarSelect');
    selectEl.innerHTML = '<option value="">Memuat kamar...</option>';
    try {
      const { data, error } = await sbClient
        .from('kamar')
        .select('*')
        .eq('kos_id', selectedKos.id)
        .eq('status', 'kosong')
        .order('nomor_kamar');

      if (error) throw error;
      bookingKamarList = data || [];

      if (!bookingKamarList.length) {
        selectEl.innerHTML = '<option value="">Tidak ada kamar kosong</option>';
      } else {
        selectEl.innerHTML = bookingKamarList
          .map(k => `<option value="${k.id}">Kamar ${k.nomor_kamar} - ${formatRupiah(k.harga)}/bln</option>`)
          .join('');
      }
    } catch (err) {
      console.error('Gagal memuat kamar:', err);
      selectEl.innerHTML = '<option value="">Gagal memuat kamar</option>';
    }

    updateBookingSummary();
    show('booking', 'detail');
  }

  // Update ringkasan harga setiap kali kamar/durasi berubah
  function updateBookingSummary() {
    const kamarId = document.getElementById('bkKamarSelect').value;
    const durasi = parseInt(document.getElementById('bkDurasi').value) || 12;
    const kamar = bookingKamarList.find(k => k.id === kamarId);
    const harga = kamar ? kamar.harga : (selectedKos ? selectedKos.harga_per_bulan : 0);

    const deposit = 300000;
    const admin = 50000;
    const sewaTotal = harga * durasi;
    const total = sewaTotal + deposit + admin;

    document.getElementById('bkLabelSewa').textContent = `Harga Kos (${durasi} bln)`;
    document.getElementById('bkValSewa').textContent = formatRupiah(sewaTotal);
    document.getElementById('bkValDeposit').textContent = formatRupiah(deposit);
    document.getElementById('bkValAdmin').textContent = formatRupiah(admin);
    document.getElementById('bkValTotal').textContent = formatRupiah(total);
  }

  // Simpan booking ke database, lalu lanjut ke halaman pembayaran
  async function handleSubmitBooking() {
    hideAuthError('bkError');
    const nama = document.getElementById('bkNama').value.trim();
    const hp = document.getElementById('bkHp').value.trim();
    const kamarId = document.getElementById('bkKamarSelect').value;
    const tanggalMasuk = document.getElementById('bkTanggalMasuk').value;
    const durasi = parseInt(document.getElementById('bkDurasi').value) || 12;

    if (!nama) return showAuthError('bkError', 'Nama lengkap wajib diisi.');
    if (!hp) return showAuthError('bkError', 'Nomor HP wajib diisi.');
    if (!kamarId) return showAuthError('bkError', 'Silakan pilih kamar.');
    if (!tanggalMasuk) return showAuthError('bkError', 'Tanggal masuk wajib diisi.');

    const kamar = bookingKamarList.find(k => k.id === kamarId);
    if (!kamar) return showAuthError('bkError', 'Kamar tidak valid, silakan pilih ulang.');

    const deposit = 300000, admin = 50000;
    const totalBayar = (kamar.harga * durasi) + deposit + admin;

    const btn = document.getElementById('bkSubmitBtn');
    btn.textContent = 'Memproses...'; btn.disabled = true;

    try {
      const { data, error } = await sbClient
        .from('booking')
        .insert({
          penyewa_id: currentUser.id,
          kamar_id: kamar.id,
          kos_id: selectedKos.id,
          nama_pemesan: nama,
          no_hp: hp,
          tanggal_masuk: tanggalMasuk,
          durasi_bulan: durasi,
          total_bayar: totalBayar,
          status: 'menunggu'
        })
        .select()
        .single();

      if (error) throw error;

      pendingBookingId = data.id;
      renderPaymentSummary(data, kamar);
      show('payment', 'booking');
    } catch (err) {
      console.error(err);
      showAuthError('bkError', err.message || 'Gagal membuat booking. Coba lagi.');
    } finally {
      btn.textContent = 'Lanjut Pembayaran →'; btn.disabled = false;
    }
  }

  // Tampilkan ringkasan di halaman Payment berdasarkan booking yang baru dibuat
  function renderPaymentSummary(booking, kamar) {
    const nameEl = document.querySelector('#screen-payment .payment-detail-card > div[style*="display:flex;gap:12px"] div div');
    const cards = document.querySelectorAll('#screen-payment .payment-detail-card > div[style*="display:flex;gap:12px"] > div > div');
    if (cards.length >= 2) {
      cards[0].textContent = selectedKos.nama_kos;
      cards[1].textContent = `Kamar ${kamar.nomor_kamar} • ${booking.durasi_bulan} Bulan`;
    }

    const sewaTotal = kamar.harga * booking.durasi_bulan;
    const deposit = 300000, admin = 50000;
    const rows = document.querySelectorAll('#screen-payment .payment-detail-card .summary-row');
    if (rows.length >= 3) {
      rows[0].querySelector('.label').textContent = `Sewa ${booking.durasi_bulan} Bulan`;
      rows[0].querySelector('.value').textContent = formatRupiah(sewaTotal);
      rows[1].querySelector('.value').textContent = formatRupiah(deposit);
      rows[2].querySelector('.value').textContent = formatRupiah(admin);
    }
    document.querySelector('#screen-payment .summary-total .value').textContent = formatRupiah(booking.total_bayar);
    const payBtn = document.getElementById('payBtn');
    if (payBtn) payBtn.textContent = `Bayar Sekarang → ${formatRupiah(booking.total_bayar)}`;
  }

  // Konfirmasi pembayaran -> update status booking & kamar, tampilkan Success, lalu refresh riwayat
  async function handleConfirmPayment() {
    if (!pendingBookingId) { showSuccess(); return; }
    try {
      await sbClient.from('booking').update({ status: 'diterima' }).eq('id', pendingBookingId);

      await sbClient.from('pembayaran').insert({
        booking_id: pendingBookingId,
        metode: 'Transfer Bank',
        jumlah: 0,
        status: 'berhasil'
      });

      const kamarId = document.getElementById('bkKamarSelect').value;
      if (kamarId) {
