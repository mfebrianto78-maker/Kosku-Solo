  async function handleTambahKos() {
    hideAuthError('tkError');
    if (!currentUser) {
      showAuthError('tkError', 'Sesi login tidak ditemukan. Silakan login ulang.');
      return;
    }

    const namaKos = document.getElementById('tkNamaKos').value.trim();
    const alamat = document.getElementById('tkAlamat').value.trim();
    const deskripsi = document.getElementById('tkDeskripsi').value.trim();
    const jenisBtn = document.querySelector('#tkJenisGrid .jenis-btn.active');
    const jenisKos = jenisBtn ? jenisBtn.dataset.jenis : 'Putra';
    const harga = parseFloat(document.getElementById('tkHarga').value);
    const jumlahKamar = parseInt(document.getElementById('tkJumlahKamar').value) || 0;
    const koordinat = document.getElementById('tkKoordinat').value.trim();

    const fasilitasChips = document.querySelectorAll('#tkFasilitasGrid .fasil-chip.active');
    const fasilitas = Array.from(fasilitasChips).map(c => c.textContent.trim());

    if (!namaKos) return showAuthError('tkError', 'Nama kos wajib diisi.');
    if (!alamat) return showAuthError('tkError', 'Alamat wajib diisi.');
    if (!harga || harga <= 0) return showAuthError('tkError', 'Harga per bulan wajib diisi dengan benar.');

    let latitude = null, longitude = null;
    if (koordinat) {
      const parts = koordinat.split(',').map(p => parseFloat(p.trim()));
      if (parts.length === 2 && !isNaN(parts[0]) && !isNaN(parts[1])) {
        latitude = parts[0]; longitude = parts[1];
      }
    }

    const btn = document.getElementById('tkSubmitBtn');
    btn.textContent = 'Menyimpan...'; btn.disabled = true;

    try {
      if (editingKosId) {
        // ===== MODE EDIT: update kos yang sudah ada =====
        const { error: updateError } = await sbClient
          .from('kos')
          .update({
            nama_kos: namaKos,
            alamat: alamat,
            deskripsi: deskripsi,
            jenis_kos: jenisKos,
            harga_per_bulan: harga,
            fasilitas: fasilitas,
            latitude: latitude,
            longitude: longitude
          })
          .eq('id', editingKosId);

        if (updateError) throw updateError;
      } else {
        // ===== MODE TAMBAH BARU: insert kos + buat kamar =====
        const { data: kosData, error: kosError } = await sbClient
          .from('kos')
          .insert({
            owner_id: currentUser.id,
            nama_kos: namaKos,
            alamat: alamat,
            deskripsi: deskripsi,
            jenis_kos: jenisKos,
            harga_per_bulan: harga,
            fasilitas: fasilitas,
            latitude: latitude,
            longitude: longitude,
            rating: 0,
            jumlah_review: 0,
            status: 'aktif'
          })
          .select()
          .single();

        if (kosError) throw kosError;

        // Buat kamar-kamar otomatis sesuai jumlah yang diinput
        if (jumlahKamar > 0 && kosData) {
          const kamarRows = [];
          for (let i = 1; i <= jumlahKamar; i++) {
            kamarRows.push({
              kos_id: kosData.id,
              nomor_kamar: String(100 + i),
              harga: harga,
              status: 'kosong',
              fasilitas: fasilitas
            });
          }
          const { error: kamarError } = await sbClient.from('kamar').insert(kamarRows);
          if (kamarError) console.error('Gagal membuat data kamar:', kamarError);
        }
      }

      await loadMyKos();
      await loadKosData(); // refresh juga listing publik
      editingKosId = null;
      showKelolaKos();
    } catch (err) {
      console.error(err);
      showAuthError('tkError', err.message || 'Gagal menyimpan kos. Coba lagi.');
    } finally {
      btn.disabled = false;
      btn.textContent = editingKosId ? '💾 Simpan Perubahan' : '💾 Simpan & Publikasikan';
    }
  }

  let myKosData = []; // cache kos milik owner yang sedang login

  // Ambil daftar kos milik owner yang sedang login, lalu render ke Dashboard Pemilik
  async function loadMyKos() {
    if (!currentUser) return;
    try {
      const { data, error } = await sbClient
        .from('kos')
        .select('*, kamar(*)')
        .eq('owner_id', currentUser.id)
        .order('created_at', { ascending: false });

      if (error) throw error;
      myKosData = data || [];
      renderOwnerStats();
    } catch (err) {
      console.error('Gagal memuat kos milik owner:', err);
    }
  }

  // Hitung & tampilkan statistik di Dashboard Pemilik berdasarkan data asli
  function renderOwnerStats() {
    let totalKos = myKosData.length;
    let totalKamar = 0, kamarTerisi = 0, kamarKosong = 0;

    myKosData.forEach(kos => {
      const kamarList = kos.kamar || [];
      totalKamar += kamarList.length;
      kamarList.forEach(k => {
        if (k.status === 'terisi') kamarTerisi++; else kamarKosong++;
      });
    });

    const statCards = document.querySelectorAll('#screen-owner .stat-val');
    if (statCards.length >= 4) {
      statCards[0].textContent = totalKos;
      statCards[1].textContent = totalKamar;
      statCards[2].textContent = kamarTerisi;
      statCards[3].textContent = kamarKosong;
    }

    const badge = document.querySelector('#screen-owner .owner-menu-badge');
    // Update badge "Kelola Kos" dengan jumlah properti
    const kelolaKosCard = Array.from(document.querySelectorAll('#screen-owner .owner-menu-card'))
      .find(c => c.textContent.includes('Kelola Kos'));
    if (kelolaKosCard) {
      const b = kelolaKosCard.querySelector('.owner-menu-badge');
      if (b) b.textContent = `${totalKos} Properti`;
    }
    const kelolaKamarCard = Array.from(document.querySelectorAll('#screen-owner .owner-menu-card'))
      .find(c => c.textContent.includes('Kelola Kamar'));
    if (kelolaKamarCard) {
      const b = kelolaKamarCard.querySelector('.owner-menu-badge');
      if (b) b.textContent = `${totalKamar} Kamar`;
    }
  }

  // Ubah nomor HP jadi format email dummy supaya bisa dipakai Supabase Auth
  function hpToEmail(hp) {
    const cleaned = hp.replace(/[^0-9]/g, '');
    return cleaned + '@koskusolo.app';
  }

  function isEmailFormat(text) {
    return text.includes('@');
  }

  // Toggle metode register: email atau No. HP
  function setRegMethod(method) {
    const emailBtn = document.getElementById('regMethodEmail');
    const hpBtn = document.getElementById('regMethodHp');
    const emailGroup = document.getElementById('regEmailGroup');
    const hpGroup = document.getElementById('regHpGroup');
    if (method === 'email') {
      emailBtn.classList.add('active'); hpBtn.classList.remove('active');
      emailGroup.style.display = 'block'; hpGroup.style.display = 'none';
    } else {
      hpBtn.classList.add('active'); emailBtn.classList.remove('active');
      hpGroup.style.display = 'block'; emailGroup.style.display = 'none';
    }
  }

  function showAuthError(elId, message) {
    const el = document.getElementById(elId);
    el.textContent = message;
    el.style.display = 'block';
  }
  function hideAuthError(elId) {
    document.getElementById(elId).style.display = 'none';
  }

  // ============================================
  // REGISTER
  // ============================================
  async function handleRegister() {
    hideAuthError('regError');
    const nama = document.getElementById('regNama').value.trim();
    const isEmailMethod = document.getElementById('regMethodEmail').classList.contains('active');
    const emailInput = document.getElementById('regEmail').value.trim();
    const hpInput = document.getElementById('regHp').value.trim();
    const password = document.getElementById('regPassword').value;
    const passwordConfirm = document.getElementById('regPasswordConfirm').value;

    if (!nama) return showAuthError('regError', 'Nama lengkap wajib diisi.');
    if (isEmailMethod && !emailInput) return showAuthError('regError', 'Email wajib diisi.');
    if (!isEmailMethod && !hpInput) return showAuthError('regError', 'Nomor HP wajib diisi.');
    if (password.length < 6) return showAuthError('regError', 'Password minimal 6 karakter.');
    if (password !== passwordConfirm) return showAuthError('regError', 'Konfirmasi password tidak sama.');

    const emailToUse = isEmailMethod ? emailInput : hpToEmail(hpInput);
    const noHpToSave = isEmailMethod ? '' : hpInput;

    const btn = document.getElementById('regSubmitBtn');
    btn.textContent = 'Mendaftarkan...'; btn.disabled = true;

    try {
      const { data, error } = await sbClient.auth.signUp({
        email: emailToUse,
        password: password,
        options: {
          data: { nama_lengkap: nama, no_hp: noHpToSave, role: 'pencari' }
        }
      });
      if (error) throw error;

      currentUser = data.user;
      // Tunggu sebentar supaya trigger handle_new_user selesai membuat row profiles
      await new Promise(r => setTimeout(r, 800));
      await loadCurrentProfile();
      showRole();
    } catch (err) {
      console.error(err);
      let msg = err.message || 'Gagal mendaftar. Coba lagi.';
      if (msg.includes('already registered') || msg.includes('already been registered')) {
        msg = isEmailMethod ? 'Email sudah terdaftar.' : 'Nomor HP sudah terdaftar.';
      }
      showAuthError('regError', msg);
    } finally {
      btn.textContent = 'Daftar Sekarang'; btn.disabled = false;
    }
  }

  // ============================================
  // LOGIN
  // ============================================
  async function handleLogin() {
    hideAuthError('loginError');
    const identifier = document.getElementById('loginIdentifier').value.trim();
    const password = document.getElementById('loginPassword').value;

    if (!identifier || !password) return showAuthError('loginError', 'Email/HP dan password wajib diisi.');

    const emailToUse = isEmailFormat(identifier) ? identifier : hpToEmail(identifier);

    const btn = document.getElementById('loginSubmitBtn');
    btn.textContent = 'Memproses...'; btn.disabled = true;

    try {
      const { data, error } = await sbClient.auth.signInWithPassword({
        email: emailToUse,
        password: password
      });
      if (error) throw error;

      currentUser = data.user;
      await loadCurrentProfile();

      // Langsung ke dashboard sesuai role yang tersimpan
      if (currentUserProfile && currentUserProfile.role === 'pemilik') {
        showOwner();
      } else {
        showDashboard();
      }
    } catch (err) {
      console.error(err);
      let msg = err.message || 'Gagal login.';
      if (msg.includes('Invalid login credentials')) msg = 'Email/HP atau password salah.';
      showAuthError('loginError', msg);
    } finally {
      btn.textContent = 'Login'; btn.disabled = false;
    }
  }

  // Simpan pilihan peran ke tabel profiles, lalu masuk ke dashboard sesuai peran
  async function setUserRole(role) {
    if (currentUser) {
      try {
        await sbClient.from('profiles').update({ role: role }).eq('id', currentUser.id);
        if (currentUserProfile) currentUserProfile.role = role;
      } catch (err) {
        console.error('Gagal menyimpan role:', err);
      }
    }
    if (role === 'pemilik') showOwner(); else showDashboard();
  }

  // Ambil data profil user yang sedang login dari tabel profiles
  async function loadCurrentProfile() {
    if (!currentUser) return;
    try {
      const { data, error } = await sbClient.from('profiles').select('*').eq('id', currentUser.id).single();
      if (error) throw error;
      currentUserProfile = data;
      applyProfileToUI();
    } catch (err) {
      console.error('Gagal memuat profil:', err);
    }
  }

  // Tampilkan nama user yang login di Dashboard & Profil
  function applyProfileToUI() {
    if (!currentUserProfile) return;
    const greetEl = document.querySelector('#screen-dashboard .dash-greeting h2');
    if (greetEl) greetEl.textContent = `Halo, ${currentUserProfile.nama_lengkap || 'Pengguna'} 👋`;
    const profilNameEl = document.querySelector('#screen-profil .profil-name');
    if (profilNameEl) profilNameEl.textContent = currentUserProfile.nama_lengkap || 'Pengguna';
    const profilEmailEl = document.querySelector('#screen-profil .profil-email');
    if (profilEmailEl) {
      const contactInfo = currentUserProfile.no_hp ? currentUserProfile.no_hp : (currentUser ? currentUser.email : '');
      profilEmailEl.textContent = contactInfo;
    }
  }

  // Cek apakah ada session aktif (user sudah login sebelumnya) saat halaman dibuka
  async function checkExistingSession() {
    try {
      const { data } = await sbClient.auth.getSession();
      if (data.session) {
        currentUser = data.session.user;
        await loadCurrentProfile();
      }
    } catch (err) {
      console.error('Gagal cek session:', err);
    }
  }

  // Logout
  async function handleLogout() {
    try { await sbClient.auth.signOut(); } catch (err) { console.error(err); }
    currentUser = null;
    currentUserProfile = null;
    showLogin();
  }
  let onboardStep = 0;
  let prevScreen = 'dashboard';

  function show(id, prev) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('screen-' + id).classList.add('active');
    currentScreen = id;
    if (prev) prevScreen = prev;
  }

  function showOnboarding() { show('onboarding'); }
  function showLogin() { show('login'); }
  function showRegister() { show('register'); }
  function showRole() { show('role'); }
  function showDashboard() { show('dashboard'); prevScreen = 'dashboard'; }
  // Navigasi "Beranda" pintar: arahkan ke dashboard sesuai role user yang sedang login
  function goToBeranda() {
    if (currentUserProfile && currentUserProfile.role === 'pemilik') {
      showOwner();
    } else {
      showDashboard();
    }
  }
  function showSearch() { show('search', currentScreen); }
  function showDetail() { show('detail', currentScreen || 'search'); }
  function showMaps() { show('maps', 'detail'); }
  function showStreetView() { show('streetview', 'maps'); }
  function showBooking() { show('booking', 'detail'); }
  function showPayment() { show('payment', 'booking'); }
  function showSuccess() { show('success'); }
  function showRiwayat() { show('riwayat'); }
  function showChat() { show('chat', currentScreen); }
  function showChatList() { show('chat-list'); }
  function goBackFromChat() { show(prevScreen); }
  function showFavorit() { show('favorit'); }
  function showProfil() {
    show('profil');
    renderProfilBottomNav();
  }

  // Tampilkan bottom nav yang sesuai di halaman Profil, tergantung role user (pencari/pemilik)
  function renderProfilBottomNav() {
    const nav = document.getElementById('profilBottomNav');
    if (!nav) return;
    const isPemilik = currentUserProfile && currentUserProfile.role === 'pemilik';

    if (isPemilik) {
      nav.innerHTML = `
        <div class="nav-item" onclick="showOwner()"><div class="nav-icon">🏠</div><div class="nav-label">Beranda</div></div>
        <div class="nav-item" onclick="showBookingMasuk()"><div class="nav-icon nav-dot">📋</div><div class="nav-label">Booking</div></div>
        <div class="nav-item" onclick="showKeuangan()"><div class="nav-icon">💰</div><div class="nav-label">Keuangan</div></div>
        <div class="nav-item" onclick="showChatList()"><div class="nav-icon">💬</div><div class="nav-label">Chat</div></div>
        <div class="nav-item active"><div class="nav-icon">👤</div><div class="nav-label" style="color:var(--orange)">Akun</div></div>`;
    } else {
      nav.innerHTML = `
        <div class="nav-item" onclick="showDashboard()"><div class="nav-icon">🏠</div><div class="nav-label">Beranda</div></div>
        <div class="nav-item" onclick="showSearch()"><div class="nav-icon">🔍</div><div class="nav-label">Cari</div></div>
        <div class="nav-item" onclick="showFavorit()"><div class="nav-icon">❤️</div><div class="nav-label">Favorit</div></div>
        <div class="nav-item" onclick="showChatList()"><div class="nav-icon nav-dot">📋</div><div class="nav-label">Pesan</div></div>
        <div class="nav-item active"><div class="nav-icon">👤</div><div class="nav-label" style="color:var(--orange)">Akun</div></div>`;
    }
  }
  function showOwner() { show('owner'); prevScreen = 'owner'; loadMyKos(); }
  function showBookingMasuk() { show('booking-masuk', 'owner'); }
  function showKeuangan() { show('keuangan', 'owner'); loadKeuangan(); }

  async function loadKeuangan() {
    if (!currentUser) return;
    try {
      // Ambil semua booking yang diterima untuk kos milik owner ini
      const kosIds = myKosData.map(k => k.id);
      if (!kosIds.length) return;

      const { data: bookings, error } = await sbClient
        .from('booking')
        .select('*')
        .in('kos_id', kosIds)
        .in('status', ['diterima', 'aktif', 'selesai']);

      if (error) throw error;

      const now = new Date();
      const bulanIni = now.getMonth();
      const tahunIni = now.getFullYear();

      // Hitung total pendapatan bulan ini
      let totalBulanIni = 0;
      const transaksi = [];
      (bookings || []).forEach(b => {
        const tgl = new Date(b.created_at);
        if (tgl.getMonth() === bulanIni && tgl.getFullYear() === tahunIni) {
          totalBulanIni += parseFloat(b.total_bayar || 0);
        }
        transaksi.push(b);
      });

      // Update UI
      const periodEl = document.getElementById('keuPeriod');
      if (periodEl) periodEl.textContent = now.toLocaleString('id-ID', { month: 'long', year: 'numeric' });
      const totalEl = document.getElementById('keuTotalPendapatan');
      if (totalEl) totalEl.textContent = formatRupiah(totalBulanIni);

      // Penyewa aktif & tingkat hunian dari myKosData
      let totalKamar = 0, kamarTerisi = 0;
      myKosData.forEach(kos => {
        (kos.kamar || []).forEach(k => {
          totalKamar++;
          if (k.status === 'terisi') kamarTerisi++;
        });
      });
      const penyewaEl = document.getElementById('keuPenyewaAktif');
      if (penyewaEl) penyewaEl.textContent = kamarTerisi;
      const hunianEl = document.getElementById('keuHunian');
      if (hunianEl) hunianEl.textContent = totalKamar ? Math.round((kamarTerisi/totalKamar)*100) + '%' : '0%';

      // Transaksi terbaru
      const transaksiEl = document.getElementById('keuTransaksi');
      if (transaksiEl) {
        if (!transaksi.length) {
          transaksiEl.innerHTML = '<div style="text-align:center;padding:20px 0;color:var(--text-3);font-size:13px">Belum ada transaksi</div>';
        } else {
          transaksiEl.innerHTML = transaksi.slice(0, 5).map(b => `
            <div class="summary-row" style="margin-bottom:10px">
              <span style="font-size:13px;color:var(--text)">${b.nama_pemesan} - ${formatRupiah(b.total_bayar)}</span>
              <span style="font-size:12px;font-weight:700;color:var(--green)">✓ ${b.status}</span>
            </div>`).join('');
        }
      }
    } catch (err) {
      console.error('Gagal memuat data keuangan:', err);
    }
  }
  function showNotif() {
    document.getElementById('notifBack').onclick = () => show(currentScreen === 'notif' ? prevScreen : currentScreen);
    show('notif', currentScreen);
  }

  // Onboarding
  function nextSlide() {
    const slides = document.querySelectorAll('.onboard-slide');
    const dots = document.querySelectorAll('.dot');
    if (onboardStep < slides.length - 1) {
      slides[onboardStep].style.transform = 'translateX(-100%)';
      onboardStep++;
      slides[onboardStep].style.transform = 'translateX(0)';
      dots.forEach((d,i) => d.classList.toggle('active', i === onboardStep));
      if (onboardStep === slides.length - 1) {
        document.getElementById('onboardNextBtn').textContent = 'Mulai';
        document.getElementById('onboardNextBtn').onclick = showLogin;
      }
    } else {
      showLogin();
    }
  }

  // Filter toggle
  function toggleFilter() {
    const p = document.getElementById('filterPanel');
    p.style.display = p.style.display === 'none' ? 'block' : 'none';
  }

  // Fasil toggle
  function toggleFasil(el) { el.classList.toggle('active'); }

  // Toggle show/hide password
  function togglePassword(inputId, iconEl) {
    const input = document.getElementById(inputId);
    if (input.type === 'password') {
      input.type = 'text';
      iconEl.textContent = '🙈';
    } else {
      input.type = 'password';
      iconEl.textContent = '👁️';
    }
  }

  // Toggle FAQ item expand/collapse
  function toggleFaq(el) {
    const answer = el.querySelector('.faq-answer');
    const arrow = el.querySelector('.menu-arrow');
    if (answer) {
      const isOpen = answer.style.display !== 'none';
      answer.style.display = isOpen ? 'none' : 'block';
      if (arrow) arrow.textContent = isOpen ? '›' : '∨';
    }
  }

  // Switch income tab di keuangan
  function switchIncomeTab(el, period) {
    el.closest('.income-tabs').querySelectorAll('.income-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  // Payment method
  function selectMethod(el) {
    document.querySelectorAll('.method-radio').forEach(r => r.classList.remove('selected'));
    el.querySelector('.method-radio').classList.add('selected');
  }

  // Tab switch
  function switchTab(el, tab) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  // Chat
  function sendMessage() {
    const input = document.getElementById('chatInput');
    const msg = input.value.trim();
    if (!msg) return;
    const container = document.getElementById('chatMessages');
    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble sent';
    const now = new Date();
    bubble.innerHTML = `<div class="bubble">${msg}</div><div class="msg-time">${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')} ✓✓</div>`;
    container.appendChild(bubble);
    input.value = '';
    container.scrollTop = container.scrollHeight;
    // Auto-reply after 1.2s
    setTimeout(() => {
      const reply = document.createElement('div');
      reply.className = 'msg-bubble received';
      reply.innerHTML = `<div class="bubble">Baik, terima kasih sudah menghubungi kami! 😊</div><div class="msg-time">${now.getHours()}:${String(now.getMinutes()+1).padStart(2,'0')}</div>`;
      container.appendChild(reply);
      container.scrollTop = container.scrollHeight;
    }, 1200);
  }

  // Category chips interaction
  document.querySelectorAll('.cat-chip').forEach(chip => {
    chip.addEventListener('click', function() {
      this.closest('.category-scroll').querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Jenis kos toggle
  document.querySelectorAll('.jenis-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      this.closest('.jenis-grid').querySelectorAll('.jenis-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Fav toggle
  document.querySelectorAll('.fav-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      this.textContent = this.textContent === '🤍' ? '❤️' : '🤍';
    });
  });

  // Income tab
  document.querySelectorAll('.income-tab').forEach(tab => {
    tab.addEventListener('click', function() {
      this.closest('.income-tabs').querySelectorAll('.income-tab').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Auto splash
  setTimeout(() => {
    if (currentScreen === 'splash') showOnboarding();
  }, 2500);

  // Load data kos dari Supabase begitu halaman dibuka
  loadKosData();
  checkExistingSession();
</script>
</body>
</html>
