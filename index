  // Buka form Tambah/Edit Kos. kosId null = mode tambah baru, ada isi = mode edit
  function showTambahKos(kosId) {
    editingKosId = kosId;
    const titleEl = document.getElementById('tkHeaderTitle');
    const btnEl = document.getElementById('tkSubmitBtn');
    const jumlahKamarGroup = document.getElementById('tkJumlahKamarGroup');

    // Reset error
    hideAuthError('tkError');

    if (kosId) {
      // MODE EDIT — isi form dengan data yang ada
      const kos = myKosData.find(k => k.id === kosId);
      if (!kos) { show('kelola-kos'); return; }

      titleEl.textContent = '✏️ Edit Kos';
      btnEl.textContent = '💾 Simpan Perubahan';
      jumlahKamarGroup.style.display = 'none'; // jumlah kamar tidak diedit di sini

      document.getElementById('tkNamaKos').value = kos.nama_kos || '';
      document.getElementById('tkAlamat').value = kos.alamat || '';
      document.getElementById('tkDeskripsi').value = kos.deskripsi || '';
      document.getElementById('tkHarga').value = kos.harga_per_bulan || '';
      document.getElementById('tkKoordinat').value = (kos.latitude && kos.longitude) ? `${kos.latitude}, ${kos.longitude}` : '';

