  // Konfirmasi sebelum hapus kos
  function confirmDeleteKos(kosId, namaKos) {
    if (confirm(`Yakin ingin menghapus "${namaKos}"? Semua data kamar terkait juga akan terhapus. Tindakan ini tidak bisa dibatalkan.`)) {
      deleteKos(kosId);
    }
  }

  async function deleteKos(kosId) {
    try {
      // Hapus kamar terkait dulu (jika tidak ada ON DELETE CASCADE aktif, ini jaga-jaga)
      await sbClient.from('kamar').delete().eq('kos_id', kosId);
      const { error } = await sbClient.from('kos').delete().eq('id', kosId);
      if (error) throw error;
      await loadMyKos();
      await loadKosData();
      renderKelolaKosList();
    } catch (err) {
      console.error(err);
      alert('Gagal menghapus kos: ' + (err.message || ''));
